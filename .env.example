# Supabase
# 從 Supabase Dashboard → Project Settings → API 取得
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_API_KEY=your_anon_key_here
# 或使用 service role key(權限更高,推薦)
SUPABASE_SERVICE_ROLE=your_service_role_key_here

# Line Messaging API
# 從 Line Developers Console → Messaging API → Channel access token 取得
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# PubMed API(選用,提高 rate limit)
# 從 NCBI 帳號設定 → API Key Management 取得
PUBMED_API_KEY=

# 日誌等級:DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
