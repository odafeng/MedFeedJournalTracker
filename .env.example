# ============================================================
# MedFeed Journal Tracker — Environment Variables
# Copy to .env.local for local dev, set these in Render for prod
# ============================================================

# ---- Supabase (required) ----
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE=eyJhbGc...      # Service role key for server-side ops

# ---- Telegram (required — replaces LINE) ----
TELEGRAM_TOKEN=123456:ABC-DEF...      # From @BotFather
TELEGRAM_CHAT_ID=123456789            # Your numeric chat ID

# ---- Anthropic Claude (required for LLM summary) ----
ANTHROPIC_API_KEY=sk-ant-api03-...
LLM_MODEL=claude-sonnet-4-5-20250929  # Override if you want a different model
LLM_DAILY_BUDGET=50                   # Max articles to process per run (hard cap)

# ---- PubMed (optional — higher rate limit with key) ----
PUBMED_API_KEY=

# ---- Notion sync (optional — set to enable Notion mirror) ----
NOTION_TOKEN=ntn_...                  # Internal integration token
NOTION_DATABASE_ID=                   # Filled after Notion DB is created

# ---- LINE (optional — parallel raw-alert channel) ----
# When set, every new article is pushed to each subscriber (filtered by
# their category) with title + authors + journal + DOI link. Independent
# of LLM processing.
# Subscribers are read from the Supabase `subscribers` table. Locally you
# can edit config/subscribers.json and they'll be upserted on the next
# run; on Render the DB is used directly.
LINE_CHANNEL_ACCESS_TOKEN=

# ---- Query Agent (LINE natural-language queries; medfeed-query-agent service) ----
# Verifies LINE's X-Line-Signature so only LINE can trigger the webhook
# (blocks anonymous POSTs that would burn API quota). Strongly recommended.
LINE_CHANNEL_SECRET=
QUERY_LLM_MODEL=claude-sonnet-4-6     # Model for the query agent
LINE_RESTRICT_TO_SUBSCRIBERS=false    # true = only answer users in `subscribers`

# ---- Semantic / hybrid search (optional — set OPENAI_API_KEY to enable) ----
# Builds article embeddings (pgvector) so the query agent's semantic_search
# can do meaning-based + keyword hybrid retrieval. Without it, search falls
# back to SQL/ILIKE automatically.
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# ---- Runtime ----
LOG_LEVEL=INFO
DAYS_BACK=7                           # How far back to fetch from RSS/PubMed
